{
  "name": "creativeid",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "db:push": "turbo run db:push --filter=@creativeid/db",
    "db:generate": "turbo run db:generate --filter=@creativeid/db",
    "db:migrate": "turbo run db:migrate --filter=@creativeid/db",
    "db:studio": "turbo run db:studio --filter=@creativeid/db"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "typescript": "^5.4.5"
  },
  "packageManager": "pnpm@9.1.0",
  "workspaces": [
    "apps/*",
    "packages/*",
    "tooling/*"
  ]
}
